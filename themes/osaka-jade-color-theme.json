  "semanticTokenColors": {
    "namespace": "#2DD5B7",
    "type": "#2DD5B7",
    "class": "#2DD5B7",
    "struct": "#2DD5B7",
    "interface": "#2DD5B7",
    "enum": "#2DD5B7",
    "typeParameter": "#2DD5B7",
    "function": "#E5C736",
    "method": "#E5C736",
    "macro": "#E5C736",
    "decorator": "#E5C736",
    "variable": "#8CD3CB",
    "parameter": "#8CD3CB",
    "property": "#8CD3CB",
    "enumMember": "#8CD3CB",
    "event": "#8CD3CB",
    "newOperator": "#D2689C",
    "keyword": "#D2689C",
    "selfKeyword": "#509475",
    "builtinType": "#509475",
    "stringLiteral": "#db9f9c",
    "numberLiteral": "#9eebb3",
    "*.readonly": "#8CD3CB"
  },
  "tokenColors": [
    {
      "scope": ["meta.embedded", "source.groovy.embedded", "string meta.image.inline.markdown", "variable.legacy.builtin.python"],
      "settings": { "foreground": "#C1C497" }
    },
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#53685B" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template", "punctuation.definition.string"],
      "settings": { "foreground": "#db9f9c" }
    },
    {
      "name": "Template expression punctuation",
      "scope": ["punctuation.definition.template-expression", "punctuation.section.embedded", "meta.template.expression"],
      "settings": { "foreground": "#D2689C" }
    },
    {
      "name": "Regular expression",
      "scope": ["string.regexp", "constant.other.character-class.regexp", "constant.character.character-class.regexp"],
      "settings": { "foreground": "#FF5345" }
    },
    {
      "name": "Escape character",
      "scope": "constant.character.escape",
      "settings": { "foreground": "#D7C995" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric", "keyword.other.unit"],
      "settings": { "foreground": "#9eebb3" }
    },
    {
      "name": "Language constant",
      "scope": ["constant.language", "constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#509475" }
    },
    {
      "name": "Constant / enum member",
      "scope": ["variable.other.constant", "variable.other.enummember", "constant.other"],
      "settings": { "foreground": "#8CD3CB" }
    },
    {
      "name": "Character constant",
      "scope": "constant.character",
      "settings": { "foreground": "#509475" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.control", "keyword.other", "punctuation.definition.keyword"],
      "settings": { "foreground": "#D2689C" }
    },
    {
      "name": "Operator (symbols)",
      "scope": ["keyword.operator", "punctuation.separator", "punctuation.terminator", "punctuation.accessor", "meta.brace"],
      "settings": { "foreground": "#C1C497" }
    },
    {
      "name": "Operator (word)",
      "scope": ["keyword.operator.new", "keyword.operator.expression", "keyword.operator.delete", "keyword.operator.typeof", "keyword.operator.instanceof", "keyword.operator.in", "keyword.operator.of", "keyword.control.new"],
      "settings": { "foreground": "#D2689C" }
    },
    {
      "name": "Storage",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#509475" }
    },
    {
      "name": "This / language variable",
      "scope": ["variable.language", "variable.language.this", "constant.language.this"],
      "settings": { "foreground": "#509475" }
    },
    {
      "name": "Type / class",
      "scope": ["entity.name.type", "entity.name.class", "entity.name.namespace", "entity.name.scope-resolution", "entity.other.inherited-class", "support.class", "support.type", "support.other.namespace", "meta.type.declaration entity.name.type"],
      "settings": { "foreground": "#2DD5B7" }
    },
    {
      "name": "Primitive type",
      "scope": ["support.type.primitive", "keyword.type"],
      "settings": { "foreground": "#509475" }
    },
    {
      "name": "Function / method",
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function", "variable.function", "meta.function-call.generic"],
      "settings": { "foreground": "#E5C736" }
    },
    {
      "name": "Decorator",
      "scope": ["meta.decorator entity.name.function", "entity.name.function.decorator", "punctuation.decorator", "meta.decorator variable.other.readwrite"],
      "settings": { "foreground": "#E5C736" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other.readwrite", "meta.definition.variable variable", "support.variable"],
      "settings": { "foreground": "#8CD3CB" }
    },
    {
      "name": "Property",
      "scope": ["variable.other.property", "variable.other.object.property", "support.variable.property", "meta.object-literal.key", "variable.object.property"],
      "settings": { "foreground": "#8CD3CB" }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#8CD3CB" }
    },
    {
      "name": "HTML / XML tag",
      "scope": ["entity.name.tag", "punctuation.definition.tag", "meta.tag"],
      "settings": { "foreground": "#509475" }
    },
    {
      "name": "HTML / XML attribute",
      "scope": ["entity.other.attribute-name", "meta.attribute"],
      "settings": { "foreground": "#8CD3CB" }
    },
    {
      "name": "CSS selector tag",
      "scope": ["entity.name.tag.css", "entity.name.tag.scss", "source.css entity.name.tag"],
      "settings": { "foreground": "#2DD5B7" }
    },
    {
      "name": "CSS class / id selector",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css", "entity.other.attribute-name.pseudo-class.css", "entity.other.attribute-name.pseudo-element.css"],
      "settings": { "foreground": "#E5C736" }
    },
    {
      "name": "CSS property name",
      "scope": ["support.type.property-name.css", "support.type.property-name", "meta.property-name"],
      "settings": { "foreground": "#8CD3CB" }
    },
    {
      "name": "CSS value",
      "scope": ["support.constant.property-value", "constant.numeric.css", "keyword.other.unit.css", "support.constant.font-name"],
      "settings": { "foreground": "#9eebb3" }
    },
    {
      "name": "JSON property name",
      "scope": ["support.type.property-name.json", "meta.object-literal.key.json"],
      "settings": { "foreground": "#8CD3CB" }
    },
    {
      "name": "YAML / TOML key",
      "scope": ["entity.name.tag.yaml", "support.type.property-name.toml"],
      "settings": { "foreground": "#8CD3CB" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal", "invalid.broken"],
      "settings": { "foreground": "#FF5345" }
    },
    {
      "name": "Deprecated",
      "scope": "invalid.deprecated",
      "settings": { "foreground": "#db9f9c" }
    },
    {
      "name": "Markdown heading",
      "scope": ["markup.heading", "entity.name.section.markdown", "punctuation.definition.heading.markdown"],
      "settings": { "foreground": "#509475", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": "markup.bold",
      "settings": { "foreground": "#2DD5B7", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": "markup.italic",
      "settings": { "foreground": "#C1C497", "fontStyle": "italic" }
    },
    {
      "name": "Markdown inline / fenced code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#db9f9c" }
    },
    {
      "name": "Markdown link",
      "scope": ["markup.underline.link", "string.other.link", "constant.other.reference.link.markdown"],
      "settings": { "foreground": "#2DD5B7" }
    },
    {
      "name": "Markdown list punctuation",
      "scope": ["punctuation.definition.list.begin.markdown", "markup.list"],
      "settings": { "foreground": "#509475" }
    },
    {
      "name": "Markdown quote",
      "scope": "markup.quote",
      "settings": { "foreground": "#53685B", "fontStyle": "italic" }
    },
    {
      "name": "Markup inserted",
      "scope": ["markup.inserted", "markup.inserted.diff", "meta.diff.header.to-file"],
      "settings": { "foreground": "#549e6a" }
    },
    {
      "name": "Markup deleted",
